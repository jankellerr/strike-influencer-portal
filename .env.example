# Postgres connection string (Neon recommended: https://neon.tech)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Yampi — API Reference: https://docs.yampi.com.br/api-reference
# Found in Yampi dashboard under Configurações > Integrações > API
YAMPI_ALIAS="your-store-alias"
YAMPI_USER_TOKEN="your-user-token"
YAMPI_SECRET_KEY="your-secret-key"
# Set when creating the webhook in Yampi; used to verify inbound webhook signatures
YAMPI_WEBHOOK_SECRET="your-webhook-secret"

# Shopify — create a custom app in the Dev Dashboard (dev.shopify.com/dashboard),
# grant it the read_products scope only, install it on your store, then copy the
# Client ID / Client secret from the app's Settings tab.
#
# On a production (paid) store, client_credentials tokens don't get scopes granted —
# use the one-time OAuth flow at /api/shopify/oauth/start instead (see README),
# which produces a permanent offline SHOPIFY_ADMIN_ACCESS_TOKEN below.
SHOPIFY_STORE_DOMAIN="your-store.myshopify.com"
SHOPIFY_CLIENT_ID="your-client-id"
SHOPIFY_CLIENT_SECRET="your-client-secret"
SHOPIFY_ADMIN_ACCESS_TOKEN="shpat_..."

# Base URL of this app, used to build short links (e.g. https://strike-links.example.com)
APP_BASE_URL="http://localhost:3000"

# Used to sign/verify influencer magic-link login tokens
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# Authorizes /api/cron/* routes. Vercel Cron sends this automatically as
# `Authorization: Bearer $CRON_SECRET` once set in your Vercel project env vars.
CRON_SECRET="generate-with-openssl-rand-base64-32"
